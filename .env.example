# --- GEMINI (Google AI Studio) ----------------------------------------------
GOOGLE_AI_API_KEY=

# --- YOUTUBE DATA API v3 ----------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
