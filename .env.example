# ============================================================
# AKHIR ZAMAAN — ENV TEMPLATE
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored; this template is safe to commit.
# ============================================================

# --- OLLAMA (local LLM) -----------------------------------------------------
# Requires `ollama serve` running locally. Model must be pulled first:
#   ollama pull gpt-oss:120b-cloud
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud

# --- TAVILY (web research for the script's modern_context section) ----------
# Optional. Without it, the pipeline falls back to LLM-only training-knowledge
# context. With it, the pipeline runs ~6 real web searches per video and
# synthesizes current 2025-2026 events into the script.
# Free tier: 1,000 searches/month at https://tavily.com (sign up, copy API key)
TAVILY_API_KEY=

# --- HUGGING FACE (Inference API for primary image generation) --------------
# Free tier with HuggingFace account at https://huggingface.co/settings/tokens
# Generate a token with 'Read' permissions. Used for:
#  1. Image generation via Flux Schnell (primary, more generous rate limits
#     than Cloudflare Workers AI free tier)
#  2. faster-whisper model downloads (higher rate limits / faster cold-start)
# Optional. Without it, images fall through to Cloudflare → Pollinations.
HF_TOKEN=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# --- TELEGRAM (used for error alerts + video delivery link) -----------------
# Required if you want the GitHub Actions workflow to send you a
# bashupload.com download link when the daily video is ready.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CHANNEL CONFIG ---------------------------------------------------------
CHANNEL_NAME=Akhir Zamaan
CHANNEL_HANDLE=@akhirzamaan

# --- PIPELINE BEHAVIOR ------------------------------------------------------
VOICE_NAME=en-GB-RyanNeural
RECITER_ID=Alafasy_128kbps
VIDEO_DURATION_MIN=15
VIDEO_DURATION_MAX=20
AUTO_TOPIC_REFILL=true
TOPIC_REFILL_THRESHOLD=20
