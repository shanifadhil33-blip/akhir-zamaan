# ============================================================
# AKHIR ZAMAAN — ENV TEMPLATE
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored; this template is safe to commit.
# ============================================================

# --- OLLAMA (local LLM) -----------------------------------------------------
# Requires `ollama serve` running locally. Model must be pulled first:
#   ollama pull gpt-oss:120b-cloud
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud

# --- TELEGRAM (used for error alerts + video delivery link) -----------------
# Required if you want the GitHub Actions workflow to send you a
# bashupload.com download link when the daily video is ready.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CHANNEL CONFIG ---------------------------------------------------------
CHANNEL_NAME=Akhir Zamaan
CHANNEL_HANDLE=@akhirzamaan

# --- PIPELINE BEHAVIOR ------------------------------------------------------
VOICE_NAME=en-GB-RyanNeural
RECITER_ID=Alafasy_128kbps
VIDEO_DURATION_MIN=15
VIDEO_DURATION_MAX=20
AUTO_TOPIC_REFILL=true
TOPIC_REFILL_THRESHOLD=20
